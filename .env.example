# Node / Python 后端共用（apps/server + apps/server_py）
# 复制为 .env 并填写密钥
# API 运行时：node（默认）| py
KRONOS_SERVER_RUNTIME=node
PORT=3001
JWT_SECRET=replace_with_strong_secret

# --- 通用 OpenAI 兼容提供商（设置后 DOUBAO_* 不再必填） ---
# AI_PROVIDER=deepseek
# AI_API_KEY=sk-your-deepseek-api-key
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-v4-pro

# --- 豆包（默认，AI_PROVIDER 为空或 doubao 时使用） ---
DOUBAO_API_KEY=replace_with_doubao_key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=ep-xxxxxx
# 规划阶段等待 tool 决策的超时（豆包常需 3–5s）；过短会跳过 web_search
# DOUBAO_PLAN_TIMEOUT_MS=8000
DOUBAO_EMBEDDING_MODEL=ep-xxxxxx
ALLOWED_ORIGIN=http://localhost:5173
ATTENTION_PY_ENABLED=false
ATTENTION_PY_BASE_URL=http://127.0.0.1:8008
ATTENTION_PY_TIMEOUT_MS=1200
# RAG: self | langchain（LC 切分 + OpenAIEmbeddings 向量写入 chunks jsonl；检索为余弦语义 + 原混合权重）
# LangChain 检索需可用的 DOUBAO_EMBEDDING_MODEL（或回退 DOUBAO_MODEL）
RAG_ENGINE_MODE=self
# 可选：self / langchain 均可用；由 ChatOpenAI 生成多路改写问句（自研走 bigram 语义极大值，langchain 走向量极大值；依赖 DOUBAO_MODEL 等）
# RAG_LC_MULTI_QUERY=false
# Playground Agent：默认 LangGraph（B）；失败自动兜底线性 plan-tool-reason（A）
# LANGGRAPH_ENABLED=true
# LANGGRAPH_MAX_TOOL_STEPS=8
# Tavily 联网搜索（web_search 工具）；未配置则 Playground 不注册该工具
TAVILY_API_KEY=tavily-dev-xxxxx
# Playground 选图 → ImgBB 图床（仅服务端持有，勿放前端）
IMGBB_API_KEY=0ad241c5455f0918974ee1346274c447
# Workflow Run：memory（默认）| redis（多实例，需 REDIS_URL）
# WORKFLOW_RUN_STORE=memory
# WORKFLOW_RUN_EVENTS_STORE=memory
# WORKFLOW_QUEUE_ENABLED=false
# REDIS_URL=redis://127.0.0.1:6379
# Playground 会话：file（默认，data/sessions）| redis（多实例，需 REDIS_URL）
# SESSION_STORE=file
# SESSION_TTL_SEC=604800
# redis 模式下异步镜像到 data/sessions（默认 true，防历史丢失）
# SESSION_FILE_MIRROR=true
# redis 下同 session 串行 SSE，防双开流（默认 true）
# SESSION_STREAM_LOCK=true
# SESSION_STREAM_LOCK_TTL_SEC=120
# AI 高并发（apps/server/src/ai）
# AI_GATEWAY_MODELS=[]
# AI_CACHE_REDIS=false
# AI_RETRIEVAL_CACHE_ENABLED=true
# AI_CHAT_ASYNC_ENABLED=false
# AI_CHAT_ASYNC_THRESHOLD_CHARS=12000
# AI_TASK_QUEUE_ENABLED=false
# AI_LOAD_PERCENT=0
# AI_TASK_STORE_REDIS=false
# AI_USER_TOKEN_BUDGET_PER_DAY=0
# AI_MODEL_TIER_ROUTING=false
# AI_MAX_CONCURRENT_SESSIONS_PER_USER=3
# AI_GLOBAL_TOKEN_QUOTA_PER_DAY=0
# AI_LOCAL_MODEL_BASE_URL=http://127.0.0.1:11434/v1
