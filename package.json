{
  "name": "kronos-agent",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @kronos/server\" \"npm run dev --workspace @kronos/web\"",
    "dev:web": "npm run dev --workspace @kronos/web",
    "dev:server": "npm run dev --workspace @kronos/server",
    "build": "npm run build --workspace @kronos/core && npm run build --workspace @kronos/server && npm run build --workspace @kronos/web",
    "cd": "node scripts/git-commit-date.mjs",
    "test": "jest --runInBand",
    "lint": "npm run lint --workspace @kronos/server && npm run lint --workspace @kronos/web",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "description": "LLM Insight Playground with LangChain-ready architecture",
  "dependencies": {
    "concurrently": "^9.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.1"
  }
}
