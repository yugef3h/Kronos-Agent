{
  "name": "kronos-agent",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @kronos/server\" \"npm run dev --workspace @kronos/web\"",
    "dev:web": "npm run dev --workspace @kronos/web",
    "dev:server": "npm run dev --workspace @kronos/server",
    "build": "npm run build --workspace @kronos/core && npm run build --workspace @kronos/server && npm run build --workspace @kronos/web",
    "test": "echo \"Tests are not wired yet\"",
    "lint": "npm run lint --workspace @kronos/web"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "description": "LLM Insight Playground with LangChain-ready architecture",
  "dependencies": {
    "concurrently": "^9.1.2"
  }
}
