{
  "name": "kronos-agent",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm --filter @kronos/web dev\"",
    "dev:web": "pnpm --filter @kronos/web dev",
    "dev:server": "node apps/server_py/dev-server.mjs",
    "dev:server:node": "pnpm --filter @kronos/server dev",
    "dev:server:py": "KRONOS_SERVER_RUNTIME=py node apps/server_py/dev-server.mjs",
    "install:server-py": "python3 -m venv apps/server_py/.venv && apps/server_py/.venv/bin/pip install -r apps/server_py/requirements.txt",
    "test:py": "apps/server_py/.venv/bin/pytest apps/server_py/tests -q",
    "dev:attention-py": "python3 -m uvicorn apps.attention_py.app:app --host 127.0.0.1 --port 8008 --reload",
    "install:attention-py": "python3 -m pip install -r apps/attention_py/requirements.txt",
    "install:crawler": "python3 -m venv apps/crawler/.venv && apps/crawler/.venv/bin/pip install -r apps/crawler/requirements.txt && apps/crawler/.venv/bin/python3 -m playwright install chromium",
    "crawl": "apps/crawler/.venv/bin/python3 apps/crawler/crawler.py",
    "build": "pnpm --filter @kronos/core build && pnpm --filter @kronos/server build && pnpm --filter @kronos/web build",
    "cd": "pnpm lint && node scripts/git-commit-date.mjs",
    "test": "jest --runInBand",
    "lint": "pnpm --filter @kronos/server lint && pnpm --filter @kronos/web lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "export:workflow-examples": "python3 apps/server/devtools/export-workflow-examples.py",
    "lockfile:check": "pnpm install --frozen-lockfile",
    "verify": "pnpm lockfile:check && pnpm lint && pnpm test && pnpm build"
  },
  "keywords": [],
  "author": "yugef3h",
  "license": "Apache-2.0",
  "description": "LLM Insight Playground with LangChain-ready architecture",
  "dependencies": {
    "concurrently": "^9.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.1"
  }
}
